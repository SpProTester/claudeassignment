# =============================================================================
# JOB PORTAL — .gitignore
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.development
.env.production
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Cache / generated
.eslintcache
.prettiercache
coverage/
.nyc_output/
*.lcov

# OS generated
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/

# Vite
*.local
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Database
*.sqlite
*.sqlite3
*.db

# Secrets / certs
*.pem
*.key
*.p12
id_rsa
id_rsa.pub

# Temp
tmp/
temp/
*.tmp
*.bak
