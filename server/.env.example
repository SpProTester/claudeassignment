# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_portal_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12

# CORS — React dev server
CLIENT_URL=http://localhost:5173
