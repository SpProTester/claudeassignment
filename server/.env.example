# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_portal_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT — separate secrets for access and refresh tokens
JWT_SECRET=your_access_token_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production

# Security
BCRYPT_ROUNDS=12

# CORS — main React app and separate admin portal
CLIENT_URL=http://localhost:5173
ADMIN_CLIENT_URL=http://localhost:5174

# Email (Nodemailer SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Job Portal <noreply@yourapp.com>"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — run `node src/scripts/create-stripe-products.js` to create them
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_BUSINESS=price_...
